# ─────────────────────────────────────────────
*.npy
*.mat
*.nc
*.h5
*.hdf5
*.zarr
data/
raw/
test_in/
stats/
aisehack-theme-2/

# ─────────────────────────────────────────────
# Model checkpoints & predictions
# ─────────────────────────────────────────────
outputs/models/*.pt
outputs/models/*.pth
outputs/submissions/*.npy
outputs/submissions/*.csv
# keep the folder structure
!outputs/models/.gitkeep
!outputs/submissions/.gitkeep

